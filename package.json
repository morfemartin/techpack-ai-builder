{
  "name": "techpack-ai-builder",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Open-source, multi-garment fashion tech pack (ficha tecnica) generator with AI-assisted translation and embroidery-spec extraction.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite-only": "vite",
    "illustrator:sample": "node scripts/generate-illustrator-comparison.mjs",
    "studio:ai": "node scripts/studio-ai.mjs",
    "studio:install": "node scripts/install-studio-service.mjs",
    "studio:uninstall": "node scripts/install-studio-service.mjs --uninstall",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.13",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.3.0",
    "vite": "^5.4.1",
    "vitest": "^2.1.9"
  }
}
