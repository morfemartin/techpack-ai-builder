# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — never prefixed with VITE_, never committed with a value.
# Read exclusively by the serverless proxy in api/deepseek.js. Because these are
# NOT VITE_-prefixed, Vite never compiles them into the browser bundle.
#
#   Local dev  → put real values in .env.local (gitignored), not here.
#   Vercel     → set under Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# DeepSeek via NVIDIA's OpenAI-compatible API. Get the key from your NVIDIA
# account. deepseek-v4-flash was tried as a cheaper/faster default but was
# observed hanging indefinitely on real chat completions (confirmed live,
# bypassing the app entirely with a direct curl) - deepseek-v4-pro is the
# known-working default until that's re-verified. The client (deepseekClient.js)
# no longer forces any model of its own, so whatever you set here is what
# every call actually uses unless a specific call overrides it (e.g. vision).
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: restrict who can call the proxy (e.g. https://your-app.vercel.app).
# Leave empty to allow same-origin only.
ALLOWED_ORIGIN=

# `npm run dev` runs a local shim (scripts/dev.mjs) that serves api/deepseek.js
# on this port and Vite proxies /api/* to it (vite.config.js) - api/deepseek.js
# is a Vercel function, plain `vite dev` never executes it on its own. You
# normally don't need to touch this; it's here in case the default port
# collides with something else on your machine.
DEV_API_PORT=3002

# ─────────────────────────────────────────────────────────────────────────────
# CLIENT-SIDE — safe to expose (no secrets). VITE_-prefixed vars ARE bundled.
# ─────────────────────────────────────────────────────────────────────────────

# Where the browser sends proxy requests. Defaults to /api/deepseek.
VITE_DEEPSEEK_PROXY_URL=/api/deepseek

# Studio-only text provider. Prefer activating it at runtime with
# `?studio=local`; this variable is useful for a dedicated private build.
# It contains no secret and points only to the loopback bridge.
VITE_TEXT_AI_PROVIDER=nvidia
VITE_LOCAL_STUDIO_AI_URL=http://127.0.0.1:11435/v1/chat/completions

# Vision model for "ficha desde foto" (src/core/visionExtract.js) - sent as
# `model` on that one call, same per-call override the proxy already supports
# for every other DeepSeek call. Swap to the 11b variant to compare
# price/latency vs. extraction accuracy without a code change.
VITE_NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# ── LEGACY (to be removed once translation fully migrates to DeepSeek) ──
# The cap prototype's Anthropic path in src/core/claudeApi.js still reads this.
# Do NOT rely on it: calling a provider directly from the browser exposes the
# key. Migration tracked in ROADMAP.md.
VITE_ANTHROPIC_API_KEY=
