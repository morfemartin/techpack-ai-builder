# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — never prefixed with VITE_, never committed with a value.
# Read exclusively by the serverless proxy in api/deepseek.js. Because these are
# NOT VITE_-prefixed, Vite never compiles them into the browser bundle.
#
#   Local dev  → put real values in .env.local (gitignored), not here.
#   Vercel     → set under Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# DeepSeek via NVIDIA's OpenAI-compatible API. Get the key from your NVIDIA
# account. Confirm the exact model id you want (see NVIDIA's model catalog).
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v3.1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: restrict who can call the proxy (e.g. https://your-app.vercel.app).
# Leave empty to allow same-origin only.
ALLOWED_ORIGIN=

# ─────────────────────────────────────────────────────────────────────────────
# CLIENT-SIDE — safe to expose (no secrets). VITE_-prefixed vars ARE bundled.
# ─────────────────────────────────────────────────────────────────────────────

# Where the browser sends proxy requests. Defaults to /api/deepseek.
VITE_DEEPSEEK_PROXY_URL=/api/deepseek

# ── LEGACY (to be removed once translation fully migrates to DeepSeek) ──
# The cap prototype's Anthropic path in src/core/claudeApi.js still reads this.
# Do NOT rely on it: calling a provider directly from the browser exposes the
# key. Migration tracked in ROADMAP.md.
VITE_ANTHROPIC_API_KEY=
